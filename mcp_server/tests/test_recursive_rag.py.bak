import unittest
import asyncio
from unittest.mock import patch, MagicMock

from fastapi.testclient import TestClient
from mcp_server.main import app

# Create mock functions for the async tools
async def mock_google_search(query):
    return "https://www.mocksite.com/page1"

async def mock_view_text_website(url):
    if url == "https://www.mocksite.com/page1":
        return "<html><body>Initial research. <a href='https://www.mocksite.com/page2'>Link</a></body></html>"
    if url == "https://www.mocksite.com/page2":
        return "<html><body>Recursive research content.</body></html>"
    return ""

class TestRecursiveRag(unittest.TestCase):
    def setUp(self):
        self.client = TestClient(app)

    # Patch the tools in the module where they are used (rag_manager)
    @patch('mcp_server.rag_manager.rag_manager.view_text_website', new=mock_view_text_website)
    @patch('mcp_server.rag_manager.rag_manager.google_search', new=mock_google_search)
    def test_ideator_with_recursive_rag(self):
        """
        Tests that the IdeatorProtocol correctly uses the enhanced RAGManager
        to perform a recursive search.
        """
        test_request = {
            "protocol_names": ["IdeatorProtocol"],
            "initial_data": {"topic": "test topic"}
        }

        response = self.client.post("/execute", json=test_request)
        self.assertEqual(response.status_code, 200)

        response_json = response.json()
        self.assertIsNone(response_json.get("error"))

        ideator_results = response_json["results"]["IdeatorProtocol"]
        research_context = ideator_results.get("research_context", "")

        # Check that content from both the initial and the recursive page is present
        self.assertIn("Initial research", research_context)
        self.assertIn("Recursive research content", research_context)

if __name__ == "__main__":
    # We need to run this test with an async test runner if we were to run it directly,
    # but `unittest discover` will handle it.
    unittest.main()
